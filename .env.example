# Copy this file to ".env" (same folder) and fill in the values below.
# .env is gitignored, so your credentials are never committed.

# Which data source the backend reads from:
#   csv  (default) -> reads data/grid_assignments.csv
#   db             -> reads the live Postgres database (analysis.* views)
DATA_BACKEND=db

# Postgres connection string. Only used when DATA_BACKEND=db.
#
# This database lives behind the VPN and requires a login, so:
#   1. Connect to the VPN first.
#   2. Put YOUR username/password and the server host/port/db name below.
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Example: postgresql://amnnguyen:s3cret@10.0.12.34:5432/grid
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
