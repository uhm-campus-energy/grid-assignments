# Copy this file to ".env" (same folder) and fill in the values below.
# .env is gitignored, so your credentials are never committed.

# --- Data source -----------------------------------------------------------
# Which data source the backend reads from:
#   csv  (default) -> reads data/grid_assignments.csv on local disk
#   blob           -> reads/writes the same CSV in Vercel Blob (used on Vercel)
#   db             -> reads the live Postgres database (analysis.* views)
DATA_BACKEND=csv

# csv backend only: override the CSV path (handy to point tests at a copy so
# they never mutate the real data file). Defaults to data/grid_assignments.csv.
# GRID_CSV_PATH=/tmp/grid_test.csv

# blob backend only. On Vercel these are set in the dashboard (connecting the
# Blob store auto-adds BLOB_READ_WRITE_TOKEN). Locally, put the token here to
# run scripts/seed_blob.py. Uncomment and fill in each line as needed:

# Token from the Vercel Blob store (Storage tab -> your store -> ".env.local"):
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Public URL printed by scripts/seed_blob.py after the first upload:
# BLOB_CSV_URL=https://xxxx.public.blob.vercel-storage.com/grid_assignments.csv

# Blob path/filename (optional; defaults to grid_assignments.csv):
# BLOB_CSV_PATHNAME=grid_assignments.csv

# db backend only: Postgres connection string (behind the VPN).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# --- Login (shared credential) ---------------------------------------------
# The app and all /api data routes require login. Choose your own values.
# Defaults are admin/admin for local dev ONLY — always override in production.
APP_USERNAME=admin
APP_PASSWORD=admin
# Secret used to sign login tokens. MUST be a long random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-to-a-long-random-string

# --- CORS (optional) -------------------------------------------------------
# Extra allowed origins (comma-separated). Not needed on Vercel (same-origin).
# CORS_ORIGINS=https://your-app.vercel.app
